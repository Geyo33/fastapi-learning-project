# Local LLM provider
LOCAL_ENDPOINT=your_local_endpoint_here/chat/completions
LOCAL_ENDPOINT_OPENAI=your_local_endpoint_here # OpenAI api compatible endpoint
LOCAL_API_KEY=your_local_api_key_here

# Alternative LLM provider
OTHER_ENDPOINT=https://example.com/v1/chat/completions
OTHER_ENDPOINT_OPENAI=https://example.com/v1 # OpenAI api compatible endpoint
OTHER_API_KEY=your_other_api_key_here

# Orders API settings
ORDERS_API_BASE_URL=http://127.0.0.1:8002/api/v1/orders
RESTAURANTS_API_BASE_URL=http://127.0.0.1:8002/api/v1/restaurants
ORDERS_API_TOKEN=your_service_token_here
ORDERS_API_TIMEOUT=30.0
ORDERS_API_TIMEOUT_CONNECT=5.0
